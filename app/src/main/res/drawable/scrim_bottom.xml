<?xml version="1.0" encoding="utf-8"?>
<!-- Bottom control scrim: opaque-ish at the very bottom, fading to transparent going up.
     Replaces the flat opaque bottom band. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="90"
        android:startColor="#C2000000"
        android:endColor="#00000000" />
</shape>
