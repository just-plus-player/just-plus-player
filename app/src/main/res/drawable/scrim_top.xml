<?xml version="1.0" encoding="utf-8"?>
<!-- Top control scrim: opaque-ish at the very top, fading to transparent so the video breathes.
     Replaces the flat opaque header band. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="270"
        android:startColor="#D9000000"
        android:endColor="#1F000000" />
</shape>
